# --- oh-my-zsh ---
export ZSH="$HOME/.oh-my-zsh"
plugins=(git macos zsh-syntax-highlighting zsh-autosuggestions)
source $ZSH/oh-my-zsh.sh

# --- prompt ---
ZSH_THEME_GIT_PROMPT_PREFIX="%{$fg_bold[blue]%} "
ZSH_THEME_GIT_PROMPT_SUFFIX="%{$reset_color%}"
ZSH_THEME_GIT_PROMPT_DIRTY="%{$fg[yellow]%} *"
ZSH_THEME_GIT_PROMPT_CLEAN=""
PROMPT=' %{$fg_bold[magenta]%}%c%{$reset_color%}$(git_prompt_info) '

# --- environment ---
export EDITOR="nvim"
export VISUAL="nvim"
export PATH="$HOME/.local/bin:$PATH"
export PATH="/opt/homebrew/bin:$PATH"
export CLAUDE_CODE_NO_FLICKER=1

# --- pnpm ---
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# --- aliases ---
# editor
alias vi='nvim'
alias vim='nvim'

# git
alias gs='git status --short'
alias ga='git add'
alias gsm='git switch main'
alias gsc='git switch -c'
alias gpcm='gh pr create --base main'

# tools
alias p="pnpm"
alias :q="exit"
alias countcode="cloc . --exclude-ext=json,md,svg,csv,toml,txt,yaml,yml --exclude-dir=node_modules,.venv,.next,dist,build,out,.git"

# navigation
alias ..="cd .."
alias dotfiles="cd ~/dotfiles/"
alias proj="cd ~/working/projects/"

# --- prs shell hook ---
prs() {
  if [[ "$1" == "cd" ]]; then
    local dest
    dest=$(command prs "$@" 2>&1)
    if [[ $? -eq 0 && -n "$dest" && -d "$dest" ]]; then
      builtin cd "$dest"
    else
      [[ -n "$dest" ]] && echo "$dest"
    fi
  else
    command prs "$@"
  fi
}

# --- fzf ---
source <(fzf --zsh)
source ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/fzf-git-sh/fzf-git.sh

# --- zoxide ---
eval "$(zoxide init zsh)"

