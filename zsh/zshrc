# --- completions ---
fpath=(/opt/homebrew/share/zsh-completions $fpath)
autoload -Uz compinit && compinit -u

# --- history ---
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_SPACE

# --- environment ---
export EDITOR="nvim"
export VISUAL="nvim"
export PATH="$HOME/.local/bin:$PATH"
export PATH="/opt/homebrew/opt/postgresql@18/bin:$PATH"

# --- pnpm ---
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# --- aliases ---
[ -f ~/dotfiles/zsh/aliases.zsh ] && source ~/dotfiles/zsh/aliases.zsh

# --- prompt ---
[ -f ~/dotfiles/zsh/zprompt.zsh ] && source ~/dotfiles/zsh/zprompt.zsh

# --- env ---
[ -f ~/dotfiles/zsh/.env ] && source ~/dotfiles/zsh/.env

# --- fzf ---
source ~/.local/share/nvim/lazy/tokyonight.nvim/extras/fzf/tokyonight_moon.sh
source <(fzf --zsh)
source ~/.local/share/fzf-git.sh/fzf-git.sh

# --- zoxide ---
eval "$(zoxide init zsh)"

# --- bat ---
export BAT_THEME="ansi"

# opencode
export PATH=$HOME/.opencode/bin:$PATH

# prs:hook:begin
eval "$(prs hook zsh)"
# prs:hook:end

# --- zsh plugins (fzf-tab before widget-wrapping plugins; history-substring-search last) ---
zstyle ':completion:*' menu no
source /opt/homebrew/opt/fzf-tab/share/fzf-tab/fzf-tab.zsh
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always --icons=auto $realpath'
zstyle ':fzf-tab:complete:*:*' fzf-preview '(bat --color=always --style=plain $realpath 2>/dev/null || eza -1 --color=always --icons=auto $realpath) 2>/dev/null'
zstyle ':fzf-tab:*' switch-group '<' '>'
ABBR_USER_ABBREVIATIONS_FILE="$HOME/dotfiles/zsh/abbreviations"
ABBR_SET_EXPANSION_CURSOR=1
source /opt/homebrew/share/zsh-abbr/zsh-abbr.zsh
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source /opt/homebrew/share/zsh-history-substring-search/zsh-history-substring-search.zsh
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
