[user]
	name = ronload
	email = 91997734+ronload@users.noreply.github.com
[include]
	path = ~/.local/share/nvim/lazy/tokyonight.nvim/extras/delta/tokyonight_moon.gitconfig
[includeIf "hasconfig:remote.*.url:git@github.com:prinsur/**"]
	path = ~/.gitconfig-prinsur
[core]
	excludesfile = ~/.gitignore_global
	editor = nvim
	pager = delta
[delta]
	navigate = true
	line-numbers = true
	syntax-theme = tokyonight_moon
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[http]
	postBuffer = 524288000
[init]
	defaultBranch = main
[push]
	default = current
	autoSetupRemote = true
[alias]
	uncommit = reset --soft HEAD~1
  unstage = restore --staged
  cleanbranch = !git branch --merged main | grep -vE '^\\*|^\\s*(main|master)$' | xargs -r git branch -d
	ds = !git diff ${1:-main} --stat #
  seto = !f() { git remote set-url origin git@github.com:ronload/$1.git; };f
