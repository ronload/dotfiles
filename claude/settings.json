{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline.sh\""
  },
  "alwaysThinkingEnabled": true,
  "permissions": {
    "allow": [
      "Grep",
      "Glob",
      "Read",
      "LS",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(tree *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "WebSearch",
      "WebFetch",
      "mcp__context7__*"
    ],
    "deny": []
  },
  "effortLevel": "high",
  "feedbackSurveyRate": 0
}
