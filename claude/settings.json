{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "USE_BUILTIN_RIPGREP": "0",
    "CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY": "20",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Grep",
      "Glob",
      "Read",
      "LS",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh run view *)",
      "Bash(gh search *)",
      "WebSearch",
      "WebFetch",
      "mcp__context7__*"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push origin main *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/notify.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/format.sh\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline.sh\""
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "modern-go-guidelines@goland-claude-marketplace": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "goland-claude-marketplace": {
      "source": {
        "source": "github",
        "repo": "JetBrains/go-modern-guidelines"
      }
    }
  },
  "feedbackSurveyRate": 0,
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "verbose": true,
  "remoteControlAtStartup": false,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "showThinkingSummary": true,
  "autoCompactWindow": 250000,
  "teammateMode": "tmux"
}
